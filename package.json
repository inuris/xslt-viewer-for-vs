{
  "name": "xslt-viewer-vs",
  "displayName": "XSLT Viewer for VS Code",
  "description": "Preview XSLT transformations and manage embedded images",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "xslt-viewer.preview",
        "title": "XSLT: Preview Transformation"
      },
      {
        "command": "xslt-viewer.revealImage",
        "title": "Reveal Image source"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xslt-viewer-sidebar",
          "title": "XSLT Viewer",
          "icon": "$(file-media)"
        }
      ]
    },
    "views": {
      "xslt-viewer-sidebar": [
        {
          "type": "webview",
          "id": "xslt-viewer-images",
          "name": "Embedded Images"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.2.5",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/test-electron": "^2.3.2",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.1.3"
  }
}
